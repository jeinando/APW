@model APW.Web.Models.ViewModels.FoodbankViewModel
@{
    ViewData["Title"] = "Food Items";
}

<div class="content-card">
    <div class="page-header">
        <h1><i class="fas fa-utensils text-primary-custom me-2"></i>Food Items</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Create New
        </a>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@ViewBag.Error
        </div>
    }

    <!-- Advanced Search -->
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-header bg-light d-flex justify-content-between align-items-center" style="cursor:pointer;" data-bs-toggle="collapse" data-bs-target="#searchPanel">
            <span><i class="fas fa-search me-2"></i><strong>Advanced Search</strong></span>
            <i class="fas fa-chevron-down"></i>
        </div>
        <div class="collapse show" id="searchPanel">
            <div class="card-body">
                <form asp-action="Index" method="get">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Name</label>
                            <input type="text" name="SearchName" value="@Model.SearchName" class="form-control form-control-sm" placeholder="Search by name..." />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Category</label>
                            <input type="text" name="SearchCategory" value="@Model.SearchCategory" class="form-control form-control-sm" placeholder="Search by category..." />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Brand</label>
                            <input type="text" name="SearchBrand" value="@Model.SearchBrand" class="form-control form-control-sm" placeholder="Search by brand..." />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Description</label>
                            <input type="text" name="SearchDescription" value="@Model.SearchDescription" class="form-control form-control-sm" placeholder="Search by description..." />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Price Min</label>
                            <input type="number" step="0.01" name="SearchPriceMin" value="@Model.SearchPriceMin" class="form-control form-control-sm" placeholder="0.00" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Price Max</label>
                            <input type="number" step="0.01" name="SearchPriceMax" value="@Model.SearchPriceMax" class="form-control form-control-sm" placeholder="0.00" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Unit</label>
                            <input type="text" name="SearchUnit" value="@Model.SearchUnit" class="form-control form-control-sm" placeholder="e.g. kg, lbs..." />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Qty In Stock</label>
                            <input type="number" name="SearchQuantityInStock" value="@Model.SearchQuantityInStock" class="form-control form-control-sm" placeholder="Exact qty..." />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Expiration From</label>
                            <input type="date" name="SearchExpirationDateFrom" value="@Model.SearchExpirationDateFrom?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Expiration To</label>
                            <input type="date" name="SearchExpirationDateTo" value="@Model.SearchExpirationDateTo?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Is Perishable</label>
                            <select name="SearchIsPerishable" class="form-select form-select-sm">
                                <option value="">-- Any --</option>
                                <option value="true" selected="@(Model.SearchIsPerishable == true)">Yes</option>
                                <option value="false" selected="@(Model.SearchIsPerishable == false)">No</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Calories/Serving</label>
                            <input type="number" name="SearchCaloriesPerServing" value="@Model.SearchCaloriesPerServing" class="form-control form-control-sm" placeholder="Exact value..." />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Ingredients</label>
                            <input type="text" name="SearchIngredients" value="@Model.SearchIngredients" class="form-control form-control-sm" placeholder="Search ingredients..." />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Barcode</label>
                            <input type="text" name="SearchBarcode" value="@Model.SearchBarcode" class="form-control form-control-sm" placeholder="Search by barcode..." />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Supplier</label>
                            <input type="text" name="SearchSupplier" value="@Model.SearchSupplier" class="form-control form-control-sm" placeholder="Search by supplier..." />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Date Added From</label>
                            <input type="date" name="SearchDateAddedFrom" value="@Model.SearchDateAddedFrom?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Date Added To</label>
                            <input type="date" name="SearchDateAddedTo" value="@Model.SearchDateAddedTo?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Is Active</label>
                            <select name="SearchIsActive" class="form-select form-select-sm">
                                <option value="">-- Any --</option>
                                <option value="true" selected="@(Model.SearchIsActive == true)">Yes</option>
                                <option value="false" selected="@(Model.SearchIsActive == false)">No</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Role ID</label>
                            <input type="number" name="SearchRoleId" value="@Model.SearchRoleId" class="form-control form-control-sm" placeholder="Role ID..." />
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button type="submit" class="btn btn-primary btn-sm">
                                <i class="fas fa-search me-1"></i>Search
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-sm">
                                <i class="fas fa-times me-1"></i>Clear
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @if (Model != null && Model.FoodItems.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Brand</th>
                        <th>Price</th>
                        <th>Qty In Stock</th>
                        <th>Supplier</th>
                        <th>Is Active</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.FoodItems)
                    {
                        <tr>
                            <td><strong>@item.FoodItemId</strong></td>
                            <td>@item.Name</td>
                            <td>@item.Category</td>
                            <td>@item.Brand</td>
                            <td>@item.Price.ToString("C")</td>
                            <td>@item.QuantityInStock</td>
                            <td>@item.Supplier</td>
                            <td>
                                @if (item.IsActive == true)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="action-buttons">
                                    <a asp-action="Details" asp-route-id="@item.FoodItemId" class="btn btn-info btn-sm">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.FoodItemId" class="btn btn-warning btn-sm">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.FoodItemId" class="btn btn-danger btn-sm">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="fas fa-utensils"></i>
            </div>
            <h3>No Food Items Found</h3>
            <p>Get started by creating your first food item.</p>
            <a asp-action="Create" class="btn btn-primary mt-3">
                <i class="fas fa-plus me-2"></i>Create Food Item
            </a>
        </div>
    }
</div>
