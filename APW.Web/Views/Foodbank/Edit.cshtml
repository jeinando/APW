@model APW.Web.Models.ViewModels.FoodbankViewModel
@{
    ViewData["Title"] = "Edit Food Item";
}

<div class="content-card">
    <div class="page-header">
        <h1><i class="fas fa-edit text-primary-custom me-2"></i>Edit Food Item</h1>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>

    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
        <input type="hidden" asp-for="FoodItemId" />
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Category" class="form-label"></label>
                <input asp-for="Category" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="Brand" class="form-label"></label>
                <input asp-for="Brand" class="form-control" />
            </div>
            <div class="col-md-8">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            </div>
            <div class="col-md-2">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label asp-for="Unit" class="form-label"></label>
                <input asp-for="Unit" class="form-control" />
            </div>
            <div class="col-md-2">
                <label asp-for="QuantityInStock" class="form-label"></label>
                <input asp-for="QuantityInStock" class="form-control" type="number" />
            </div>
            <div class="col-md-3">
                <label asp-for="ExpirationDate" class="form-label"></label>
                <input asp-for="ExpirationDate" class="form-control" type="date" />
            </div>
            <div class="col-md-2">
                <label asp-for="IsPerishable" class="form-label"></label>
                <select asp-for="IsPerishable" class="form-select">
                    <option value="">-- Select --</option>
                    <option value="true">Yes</option>
                    <option value="false">No</option>
                </select>
            </div>
            <div class="col-md-2">
                <label asp-for="CaloriesPerServing" class="form-label"></label>
                <input asp-for="CaloriesPerServing" class="form-control" type="number" />
            </div>
            <div class="col-md-8">
                <label asp-for="Ingredients" class="form-label"></label>
                <textarea asp-for="Ingredients" class="form-control" rows="2"></textarea>
            </div>
            <div class="col-md-4">
                <label asp-for="Barcode" class="form-label"></label>
                <input asp-for="Barcode" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="Supplier" class="form-label"></label>
                <input asp-for="Supplier" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="DateAdded" class="form-label"></label>
                <input asp-for="DateAdded" class="form-control" type="datetime-local" />
            </div>
            <div class="col-md-2">
                <label asp-for="IsActive" class="form-label"></label>
                <select asp-for="IsActive" class="form-select">
                    <option value="">-- Select --</option>
                    <option value="true">Yes</option>
                    <option value="false">No</option>
                </select>
            </div>
            <div class="col-md-2">
                <label asp-for="RoleId" class="form-label"></label>
                <input asp-for="RoleId" class="form-control" type="number" />
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-warning">
                <i class="fas fa-save me-2"></i>Save Changes
            </button>
            <a asp-action="Details" asp-route-id="@Model.FoodItemId" class="btn btn-info">
                <i class="fas fa-eye me-2"></i>Details
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-times me-2"></i>Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
