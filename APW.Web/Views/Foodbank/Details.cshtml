@model APW.Web.Models.ViewModels.FoodbankViewModel
@{
    ViewData["Title"] = "Food Item Details";
}

<div class="content-card">
    <div class="page-header">
        <h1><i class="fas fa-utensils text-primary-custom me-2"></i>Food Item Details</h1>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@ViewBag.Error
        </div>
    }

    <div class="row">
        <div class="col-md-6">
            <dl class="row">
                <dt class="col-sm-4">ID</dt>
                <dd class="col-sm-8">@Model.FoodItemId</dd>

                <dt class="col-sm-4">Name</dt>
                <dd class="col-sm-8">@Model.Name</dd>

                <dt class="col-sm-4">Category</dt>
                <dd class="col-sm-8">@Model.Category</dd>

                <dt class="col-sm-4">Brand</dt>
                <dd class="col-sm-8">@Model.Brand</dd>

                <dt class="col-sm-4">Description</dt>
                <dd class="col-sm-8">@Model.Description</dd>

                <dt class="col-sm-4">Price</dt>
                <dd class="col-sm-8">@Model.Price.ToString("C")</dd>

                <dt class="col-sm-4">Unit</dt>
                <dd class="col-sm-8">@Model.Unit</dd>

                <dt class="col-sm-4">Qty In Stock</dt>
                <dd class="col-sm-8">@Model.QuantityInStock</dd>

                <dt class="col-sm-4">Expiration Date</dt>
                <dd class="col-sm-8">@Model.ExpirationDate?.ToString("yyyy-MM-dd")</dd>
            </dl>
        </div>
        <div class="col-md-6">
            <dl class="row">
                <dt class="col-sm-4">Is Perishable</dt>
                <dd class="col-sm-8">
                    @if (Model.IsPerishable == true)
                    {
                        <span class="badge bg-warning text-dark">Yes</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">No</span>
                    }
                </dd>

                <dt class="col-sm-4">Calories/Serving</dt>
                <dd class="col-sm-8">@Model.CaloriesPerServing</dd>

                <dt class="col-sm-4">Ingredients</dt>
                <dd class="col-sm-8">@Model.Ingredients</dd>

                <dt class="col-sm-4">Barcode</dt>
                <dd class="col-sm-8">@Model.Barcode</dd>

                <dt class="col-sm-4">Supplier</dt>
                <dd class="col-sm-8">@Model.Supplier</dd>

                <dt class="col-sm-4">Date Added</dt>
                <dd class="col-sm-8">@Model.DateAdded?.ToString("yyyy-MM-dd HH:mm")</dd>

                <dt class="col-sm-4">Is Active</dt>
                <dd class="col-sm-8">
                    @if (Model.IsActive == true)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactive</span>
                    }
                </dd>

                <dt class="col-sm-4">Role ID</dt>
                <dd class="col-sm-8">@Model.RoleId</dd>
            </dl>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.FoodItemId" class="btn btn-warning">
            <i class="fas fa-edit me-2"></i>Edit
        </a>
        <a asp-action="Delete" asp-route-id="@Model.FoodItemId" class="btn btn-danger">
            <i class="fas fa-trash me-2"></i>Delete
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>
</div>
